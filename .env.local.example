# =========================================================================
# AnalyticsRise Local Environment Variables Template
# Copy this file to '.env.local' and replace the placeholders with your values.
# =========================================================================

# -------------------------------------------------------------------------
# Firebase Client SDK Configuration (Exposed to the Browser)
# These credentials initialize the client-side Firebase SDK.
# -------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=analyticsrise-56655
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=analyticsrise-56655.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# -------------------------------------------------------------------------
# Firebase Admin SDK Configuration (Server-Side Only - Private)
# Used by Next.js Server Components, API Routes, or Server Actions.
# WARNING: Never prefix these with 'NEXT_PUBLIC_'.
# -------------------------------------------------------------------------
# JSON string representation of the service account credential file
FIREBASE_ADMIN_SDK_KEY=your_firebase_admin_private_key_json_string

# -------------------------------------------------------------------------
# Application Environment & Hosts
# -------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# -------------------------------------------------------------------------
# Feature Flags (Toggles for platform layouts)
# -------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_SIMULATORS=true
NEXT_PUBLIC_ENABLE_COMMUNITY=true
NEXT_PUBLIC_ENABLE_CERTIFICATIONS=true

# -------------------------------------------------------------------------
# Analytics Integration
# -------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_measurement_id
